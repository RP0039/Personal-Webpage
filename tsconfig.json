{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@components/*":["./src/components/*"],
      "@layout/*":["./src/layout/*"],
      "@pages/*":["./src/pages/*"],
      "@assets/*":["./src/assets/*"],
      "@styles/*":["./src/styles/*"]
    }
  }
}
