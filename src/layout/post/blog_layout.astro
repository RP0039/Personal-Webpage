---
import Layout from "@layout/layout.astro"

import '/src/styles/Blog.css'
import '/src/styles/togglemode.css'
---

<Layout title="My personal blog">
<main class="home-container"> 

   <div style="margin:0 auto;margin-bottom:15px;" class="titulo">
        <h1>What’s Next?</h1>
        <p>Turn the page and find out.</p>
   </div>

    <section class="main-content" id="updates">
        <slot />
    </section>
</main>
</Layout>

